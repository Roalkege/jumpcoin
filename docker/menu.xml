<?xml version="1.0" encoding="UTF-8"?>
<openbox_menu>
    <menu id="root-menu" label="Jumpcoin">
        <item label="Start / Restart Jumpcoin-Qt">
            <action name="Execute">
                <command>/usr/local/bin/launch-jumpcoin-qt</command>
            </action>
        </item>
        <separator/>
        <item label="Reconfigure Openbox">
            <action name="Reconfigure" />
        </item>
        <item label="Restart Openbox">
            <action name="Restart" />
        </item>
        <separator/>
        <item label="Exit Openbox Session">
            <action name="Exit">
                <prompt>yes</prompt>
            </action>
        </item>
    </menu>
</openbox_menu>
